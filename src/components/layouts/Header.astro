---
import { Image } from 'astro:assets';
import ThemeToggle from '@components/ui/ThemeToggle.astro';
import LanguageSwitcher from '@components/ui/LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, defaultLanguage } from '@/i18n/utils';

interface Props {
  activeSection?: 'home' | 'projects' | 'stats' | 'stack' | 'about' | 'contact';
}

const { activeSection } = Astro.props as Props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isHome = !activeSection || activeSection === 'home';

const navItems = [
  { id: 'projects', label: t('nav.projects'), href: getLocalizedPath('/projects', lang) },
  { id: 'stats', label: t('nav.numbers'), href: `${getLocalizedPath('/', lang)}#stats` },
  { id: 'stack', label: t('nav.stack'), href: `${getLocalizedPath('/', lang)}#stack` },
  { id: 'about', label: t('nav.about'), href: `${getLocalizedPath('/', lang)}#about` },
  { id: 'contact', label: t('nav.contact'), href: `${getLocalizedPath('/', lang)}#contact` },
];

const homeHref = getLocalizedPath('/', lang);
const localizedHome = lang === defaultLanguage ? '/' : `/${lang}/`;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border/60 bg-bg/80 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-6 md:px-10"
  >
    <a
      href={homeHref}
      class="flex items-center gap-2 text-sm font-bold tracking-tight"
      aria-label="Home"
    >
      <span
        class="relative inline-block h-7 w-7 overflow-hidden rounded-full ring-1 ring-border"
        transition:name="site-logo"
        transition:animate="fade"
      >
        <Image
          src={import('@/assets/avatar/avatar-256.png')}
          alt="Leonardo Serrano"
          width={28}
          height={28}
          loading="eager"
          class="h-full w-full object-cover"
        />
      </span>
      <span transition:name="site-name" transition:animate="fade">Leonardo Serrano</span>
    </a>
    <nav class="flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'hidden rounded-md px-3 py-1.5 text-sm transition md:inline-flex',
              activeSection === item.id
                ? 'text-text'
                : 'text-text-soft hover:text-text',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      {
        !isHome && lang === defaultLanguage && (
          <a
            href={localizedHome}
            class="ml-1 hidden rounded-md bg-bg-soft px-3 py-1.5 text-sm font-medium text-text transition hover:border-secundario hover:text-secundario md:inline-flex"
          >
            ← {t('nav.home')}
          </a>
        )
      }
      <div class="ml-2">
        <LanguageSwitcher />
      </div>
      <div class="ml-1">
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>
