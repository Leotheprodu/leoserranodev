---
interface Props {
  cols?: 1 | 2 | 3 | 4;
  gap?: 'sm' | 'md' | 'lg';
  class?: string;
  as?: 'div' | 'section';
}

const {
  cols = 3,
  gap = 'md',
  class: className = '',
  as: Tag = 'div',
} = Astro.props as Props;

const colsMap = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};

const gapMap = {
  sm: 'gap-3',
  md: 'gap-6',
  lg: 'gap-8',
};
---

<Tag class:list={['grid', colsMap[cols], gapMap[gap], className]}>
  <slot />
</Tag>
