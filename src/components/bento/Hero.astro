---
import Button from '@components/ui/Button.astro';
import Heading from '@components/ui/Heading.astro';
import Badge from '@components/ui/Badge.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string; target?: '_blank' };
  secondaryCta?: { label: string; href: string; target?: '_blank' };
  stack?: string[];
  variant?: 'default' | 'centered' | 'compact';
}

const {
  eyebrow = 'Building in public',
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  stack,
  variant = 'centered',
} = Astro.props as Props;
---

<section
  class:list={[
    'relative overflow-hidden',
    variant === 'compact' ? 'py-16 md:py-20' : 'py-20 md:py-32',
  ]}
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_25%_20%,var(--color-secundario)/10,transparent_45%),radial-gradient(circle_at_75%_80%,var(--color-acento)/10,transparent_45%)]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-border to-transparent"
  >
  </div>

  <div
    class:list={[
      'mx-auto flex max-w-7xl gap-12 px-6 md:px-10',
      variant === 'centered'
        ? 'flex-col items-center text-center'
        : 'flex-col items-start text-left md:flex-row md:items-center md:justify-between',
    ]}
  >
    <div
      class:list={[
        'flex flex-col gap-6',
        variant === 'centered' ? 'items-center' : 'items-start',
      ]}
    >
      <Badge variant="secundario" size="md">
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-secundario opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-secundario"
          ></span>
        </span>
        {eyebrow}
      </Badge>

      <Heading
        as="h1"
        size="6xl"
        weight="black"
        gradient
        class="max-w-5xl"
      >
        {title}
      </Heading>

      {subtitle && (
        <p
          class:list={[
            'max-w-2xl text-balance text-lg text-text-soft md:text-xl',
          ]}
        >
          {subtitle}
        </p>
      )}

      {(primaryCta || secondaryCta) && (
        <div
          class:list={[
            'mt-2 flex flex-wrap gap-3',
            variant === 'centered' ? 'justify-center' : 'justify-start',
          ]}
        >
          {primaryCta && (
            <Button
              href={primaryCta.href}
              target={primaryCta.target}
              variant="primary"
              size="lg"
            >
              {primaryCta.label}
              <span slot="icon-right" aria-hidden="true">→</span>
            </Button>
          )}
          {secondaryCta && (
            <Button
              href={secondaryCta.href}
              target={secondaryCta.target}
              variant="outline"
              size="lg"
            >
              {secondaryCta.label}
            </Button>
          )}
        </div>
      )}

      {stack && stack.length > 0 && (
        <div
          class:list={[
            'mt-6 flex flex-wrap items-center gap-2 text-xs text-text-muted',
            variant === 'centered' ? 'justify-center' : 'justify-start',
          ]}
        >
          <span>Stack:</span>
          {stack.map((tech) => (
            <Badge variant="outline" size="sm">{tech}</Badge>
          ))}
        </div>
      )}
    </div>

    <slot />
  </div>
</section>
