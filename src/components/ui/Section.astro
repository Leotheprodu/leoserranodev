---
type Container = 'narrow' | 'wide' | 'full';
type Background = 'default' | 'soft' | 'surface' | 'primario' | 'gradient';
type Spacing = 'sm' | 'md' | 'lg' | 'xl';

interface Props {
  id?: string;
  container?: Container;
  background?: Background;
  spacing?: Spacing;
  class?: string;
  as?: 'section' | 'div' | 'article' | 'main' | 'header' | 'footer';
}

const {
  id,
  container = 'wide',
  background = 'default',
  spacing = 'lg',
  class: className = '',
  as: Tag = 'section',
} = Astro.props as Props;

const containers: Record<Container, string> = {
  narrow: 'max-w-4xl',
  wide: 'max-w-7xl',
  full: 'max-w-none',
};

const backgrounds: Record<Background, string> = {
  default: 'bg-bg',
  soft: 'bg-bg-soft',
  surface: 'bg-surface',
  primario: 'bg-primario text-bg',
  gradient:
    'bg-gradient-to-br from-bg via-bg-soft to-bg relative overflow-hidden',
};

const spacings: Record<Spacing, string> = {
  sm: 'py-12 md:py-16',
  md: 'py-16 md:py-20',
  lg: 'py-20 md:py-28',
  xl: 'py-28 md:py-36',
};

const innerClasses = [
  containers[container],
  'mx-auto px-6 md:px-10',
].join(' ');

const sectionClasses = [backgrounds[background], spacings[spacing], className]
  .filter(Boolean)
  .join(' ');
---

<Tag id={id} class={sectionClasses}>
  <div class={innerClasses}>
    <slot />
  </div>
</Tag>
