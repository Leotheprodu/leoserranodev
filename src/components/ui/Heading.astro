---
type As = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
type Size = 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl' | '6xl';
type Weight = 'normal' | 'medium' | 'semibold' | 'bold' | 'black';

interface Props {
  as?: As;
  size?: Size;
  weight?: Weight;
  gradient?: boolean;
  balance?: boolean;
  eyebrow?: string;
  id?: string;
  class?: string;
}

const {
  as: Tag = 'h2',
  size = '2xl',
  weight = 'bold',
  gradient = false,
  balance = true,
  eyebrow,
  id,
  class: className = '',
} = Astro.props as Props;

const sizeMap: Record<Size, string> = {
  xs: 'text-xs',
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
  xl: 'text-xl md:text-2xl',
  '2xl': 'text-2xl md:text-3xl',
  '3xl': 'text-3xl md:text-4xl',
  '4xl': 'text-4xl md:text-5xl',
  '5xl': 'text-5xl md:text-6xl',
  '6xl': 'text-6xl md:text-7xl',
};

const weightMap: Record<Weight, string> = {
  normal: 'font-normal',
  medium: 'font-medium',
  semibold: 'font-semibold',
  bold: 'font-bold',
  black: 'font-black',
};

const classes = [
  sizeMap[size],
  weightMap[weight],
  'tracking-tight',
  balance && 'text-balance',
  gradient && 'text-gradient',
  className,
]
  .filter(Boolean)
  .join(' ');
---

{eyebrow && (
  <span
    class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-secundario"
  >
    {eyebrow}
  </span>
)}

<Tag id={id} class={classes}>
  <slot />
</Tag>
