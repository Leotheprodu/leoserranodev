---
import { getCollection, render } from 'astro:content';
import CaseStudyLayout from '@layouts/CaseStudyLayout.astro';
import Card from '@components/ui/Card.astro';
import Heading from '@components/ui/Heading.astro';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map((p) => ({
    params: { slug: p.data.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const others = allProjects
  .filter((p) => p.data.slug !== entry.data.slug)
  .sort((a, b) => a.data.order - b.data.order);
---

<CaseStudyLayout
  title={`${entry.data.title} — Case Study`}
  description={lang === 'es' && entry.data.esTagline ? entry.data.esTagline : entry.data.tagline}
  tagline={lang === 'es' && entry.data.esTagline ? entry.data.esTagline : entry.data.tagline}
  type={entry.data.type}
  status={entry.data.status}
  statusVariant="live"
  liveUrl={entry.data.liveUrl}
  githubUrl={entry.data.githubUrl}
  stack={entry.data.stack}
  metrics={entry.data.metrics}
  highlights={lang === 'es' && entry.data.esHighlights ? entry.data.esHighlights : entry.data.highlights}
  publishedAt={entry.data.publishedAt}
>
  <Content />

  <Fragment slot="related">
    {
      others.map((p) => (
        <Card
          variant="bento"
          padding="md"
          hover="border"
          href={`/projects/${p.data.slug}`}
        >
          <div class="flex flex-col gap-2">
            <Badge variant="default" size="sm">
              {p.data.type === 'saas'
                ? 'SaaS'
                : p.data.type === 'ecommerce'
                  ? 'E-commerce'
                  : p.data.type === 'studio'
                    ? 'Studio'
                    : 'Platform'}
            </Badge>
            <Heading as="h3" size="lg">{p.data.title}</Heading>
            <p class="text-sm text-text-soft line-clamp-2">
              {lang === 'es' && p.data.esTagline ? p.data.esTagline : p.data.tagline}
            </p>
            <Button variant="link" size="sm" href={`/projects/${p.data.slug}`}>
              {t('common.readCaseStudy')} →
            </Button>
          </div>
        </Card>
      ))
    }
  </Fragment>
</CaseStudyLayout>
