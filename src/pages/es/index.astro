---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import Heading from '@components/ui/Heading.astro';
import Badge from '@components/ui/Badge.astro';
import Section from '@components/ui/Section.astro';
import Header from '@components/layouts/Header.astro';
import Footer from '@components/layouts/Footer.astro';
import Icon from '@components/ui/Icon.astro';
import Reveal from '@components/motion/Reveal.astro';
import StaggerChildren from '@components/motion/StaggerChildren.astro';
import Hero from '@components/bento/Hero.astro';
import ProjectCard from '@components/bento/ProjectCard.astro';
import StatCard from '@components/bento/StatCard.astro';
import BentoGrid from '@components/bento/BentoGrid.astro';
import StackSection from '@components/bento/StackSection.astro';
import ContactSection from '@components/bento/ContactSection.astro';
import SnippetsShowcase from '@components/bento/SnippetsShowcase.astro';
import { headlineStats, localizeStat } from '@data/stats';
import { stack } from '@data/stack';
import { useTranslations, getLocalizedPath, defaultLanguage } from '@/i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);
const homePath = getLocalizedPath('/', lang);

const allProjects = await getCollection('projects');
const projectsByOrder = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    slug: p.data.slug,
    title: p.data.title,
    tagline: p.data.esTagline ?? p.data.tagline,
    description: p.data.esDescription ?? p.data.description!,
    type: p.data.type,
    status: p.data.status,
    url: p.data.liveUrl,
    githubUrl: p.data.githubUrl,
    liveLabel: p.data.liveUrl
      ? p.data.liveUrl.replace(/^https?:\/\/(www\.)?/, '')
      : undefined,
    stack: p.data.stack,
    highlights: p.data.esHighlights ?? p.data.highlights,
    metrics: p.data.metrics,
    featured: p.data.featured,
    order: p.data.order,
  }));
---

<BaseLayout
  title="Leonardo Serrano — Ingeniero Full-Stack de Costa Rica"
  description={t('hero.subtitle')}
>
  <Header />

  <main>
    <Hero
      eyebrow={t('hero.eyebrow')}
      title={t('hero.title')}
      subtitle={t('hero.subtitle')}
      primaryCta={{ label: t('hero.primaryCta'), href: '#projects' }}
      secondaryCta={{ label: t('hero.secondaryCta'), href: '#contact' }}
      stack={['Astro 5', 'React 19', 'Tailwind 4', 'NestJS', 'Prisma', 'Socket.IO']}
    />

    <Section id="stats" container="wide" background="soft" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">{t('stats.eyebrow')}</Badge>
        <Heading as="h2" size="4xl" gradient>
          {t('stats.title')}
        </Heading>
        <p class="max-w-2xl text-text-soft">{t('stats.subtitle')}</p>
      </Reveal>

      <BentoGrid cols={3} gap="md">
        {headlineStats.map((s) => <StatCard stat={localizeStat(s, 'es')} size="md" highlight={s.highlight} />)}
      </BentoGrid>
    </Section>

    <Section id="projects" container="wide" background="default" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">{t('projects.eyebrow')}</Badge>
        <Heading as="h2" size="4xl" gradient>
          {t('projects.title')}
        </Heading>
        <p class="max-w-2xl text-text-soft">{t('projects.subtitle')}</p>
      </Reveal>

      <StaggerChildren
        as="div"
        stagger={120}
        initialDelay={100}
        class="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
      >
        {projectsByOrder.map((project, i) => (
          <ProjectCard
            project={project}
            variant={i === 0 ? 'wide' : 'default'}
          />
        ))}
      </StaggerChildren>
    </Section>

    <Section id="stack" container="wide" background="soft" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">{t('stack.eyebrow')}</Badge>
        <Heading as="h2" size="4xl" gradient>
          {t('stack.title')}
        </Heading>
        <p class="max-w-2xl text-text-soft">{t('stack.subtitle')}</p>
      </Reveal>

      <StaggerChildren
        as="div"
        stagger={80}
        initialDelay={0}
        class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        {stack.map((category) => (
          <div class="rounded-lg border border-border bg-surface p-6">
            <div class="mb-4 flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-md bg-secundario/10 text-secundario">
                <Icon name={category.icon} size={18} ariaLabel={category.title} />
              </span>
              <h3 class="text-base font-bold text-text">{category.title}</h3>
            </div>
            <ul class="flex flex-col gap-2">
              {category.items.map((item) => (
                <li class="flex items-center justify-between gap-2 text-sm">
                  <span class="text-text">{item.name}</span>
                  <div class="flex items-center gap-1.5">
                    {item.years && (
                      <span class="text-xs text-text-muted">
                        {item.years}{t('common.yearsShort')}
                      </span>
                    )}
                    {item.level && (
                      <Badge variant="outline" size="sm">
                        {item.level === 'expert'
                          ? 'Experto'
                          : item.level === 'proficient'
                            ? 'Competente'
                            : 'Aprendiendo'}
                      </Badge>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </StaggerChildren>
    </Section>

    <Section id="about" container="narrow" background="default" spacing="lg">
      <Reveal direction="up" speed="normal" class="flex flex-col items-center gap-6 text-center">
        <Badge variant="default" size="sm">{t('about.eyebrow')}</Badge>
        <Heading as="h2" size="4xl">
          {t('about.title')}<span class="text-gradient">{t('about.titleHighlight')}</span>
        </Heading>
        <StaggerChildren
          as="div"
          stagger={120}
          initialDelay={100}
          class="max-w-2xl space-y-4 text-left text-lg text-text-soft"
        >
          <p>
            {t('about.p1')} <strong class="text-text">{t('about.p1Strong1')}</strong>{' '}
            {t('about.p1Strong2')}
          </p>
          <p>
            {t('about.p2')} <strong class="text-text">{t('about.p2Strong1')}</strong>{' '}
            {t('about.p2Strong2')} <strong class="text-text">{t('about.p2Strong3')}</strong>{' '}
            {t('about.p2Strong4')}
          </p>
          <p>{t('about.p3')}</p>
        </StaggerChildren>
      </Reveal>
    </Section>

    <Reveal direction="up" speed="normal">
      <ContactSection />
    </Reveal>
  </main>

  <Footer />
</BaseLayout>
