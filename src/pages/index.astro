---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import Heading from '@components/ui/Heading.astro';
import Badge from '@components/ui/Badge.astro';
import Card from '@components/ui/Card.astro';
import Hero from '@components/bento/Hero.astro';
import ProjectCard from '@components/bento/ProjectCard.astro';
import StatCard from '@components/bento/StatCard.astro';
import BentoGrid from '@components/bento/BentoGrid.astro';
import StackSection from '@components/bento/StackSection.astro';
import ContactSection from '@components/bento/ContactSection.astro';
import Section from '@components/ui/Section.astro';
import ThemeToggle from '@components/ui/ThemeToggle.astro';
import Icon from '@components/ui/Icon.astro';
import Reveal from '@components/motion/Reveal.astro';
import StaggerChildren from '@components/motion/StaggerChildren.astro';
import { projectsByOrder } from '@data/projects';
import { headlineStats } from '@data/stats';
import { stack } from '@data/stack';
---

<BaseLayout
  title="Leonardo Serrano — Full-Stack Engineer from Costa Rica"
  description="Building production systems that scale. 4 live products, 159K+ lines of code, real users in production. 13+ years shipping software."
>
  <header
    class="sticky top-0 z-50 w-full border-b border-border/60 bg-bg/80 backdrop-blur-md"
  >
    <Reveal direction="down" speed="fast" distance={-8} as="div" class="contents">
      <div
        class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-6 md:px-10"
      >
        <a
          href="/"
          class="flex items-center gap-2 text-sm font-bold tracking-tight"
        >
          <span
            class="grid h-7 w-7 place-items-center rounded-md bg-primario text-bg"
          >
            L
          </span>
          <span>Leonardo Serrano</span>
        </a>
        <nav class="flex items-center gap-2">
          <a
            href="#projects"
            class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
          >
            Projects
          </a>
          <a
            href="#stats"
            class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
          >
            Numbers
          </a>
          <a
            href="#stack"
            class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
          >
            Stack
          </a>
          <a
            href="#about"
            class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
          >
            About
          </a>
          <a
            href="#contact"
            class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
          >
            Contact
          </a>
          <ThemeToggle />
        </nav>
      </div>
    </Reveal>
  </header>

  <main>
    <Hero
      eyebrow="Building in public"
      title="Full-stack engineer building production systems that scale"
      subtitle="Costa Rica · 4 live products · 159K+ lines of code · real users every day. I run a recording studio and ship SaaS on the side."
      primaryCta={{ label: 'See the work', href: '#projects' }}
      secondaryCta={{ label: 'Get in touch', href: '#contact' }}
      stack={['Astro 5', 'React 19', 'Tailwind 4', 'NestJS', 'Prisma', 'Socket.IO']}
    />

    <Section id="stats" container="wide" background="soft" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">Numbers</Badge>
        <Heading as="h2" size="4xl" gradient>
          What 13 years of shipping looks like
        </Heading>
        <p class="max-w-2xl text-text-soft">
          Real metrics from production codebases, not vanity numbers.
        </p>
      </Reveal>

      <BentoGrid cols={3} gap="md">
        {headlineStats.map((stat) => <StatCard stat={stat} size="md" />)}
      </BentoGrid>
    </Section>

    <Section id="projects" container="wide" background="default" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">Featured</Badge>
        <Heading as="h2" size="4xl" gradient>
          What I'm shipping right now
        </Heading>
        <p class="max-w-2xl text-text-soft">
          Four production systems, each one a different domain, all built from
          scratch.
        </p>
      </Reveal>

      <StaggerChildren
        as="div"
        stagger={120}
        initialDelay={100}
        class="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
      >
        {projectsByOrder.map((project, i) => (
          <ProjectCard
            project={project}
            variant={i === 0 ? 'wide' : 'default'}
          />
        ))}
      </StaggerChildren>
    </Section>

    <Section id="stack" container="wide" background="soft" spacing="lg">
      <Reveal direction="up" speed="normal" class="mb-12 flex flex-col items-center gap-3 text-center">
        <Badge variant="default" size="sm">Stack</Badge>
        <Heading as="h2" size="4xl" gradient>
          What I work with
        </Heading>
        <p class="max-w-2xl text-text-soft">
          Tools I've shipped to production. Grouped by layer, ordered by how
          much I've used them.
        </p>
      </Reveal>

      <StaggerChildren
        as="div"
        stagger={80}
        initialDelay={0}
        class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        {stack.map((category) => (
          <div class="rounded-lg border border-border bg-surface p-6">
            <div class="mb-4 flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-md bg-secundario/10 text-secundario">
                <Icon name={category.icon} size={18} ariaLabel={category.title} />
              </span>
              <h3 class="text-base font-bold text-text">{category.title}</h3>
            </div>
            <ul class="flex flex-col gap-2">
              {category.items.map((item) => (
                <li class="flex items-center justify-between gap-2 text-sm">
                  <span class="text-text">{item.name}</span>
                  <div class="flex items-center gap-1.5">
                    {item.years && (
                      <span class="text-xs text-text-muted">{item.years}y</span>
                    )}
                    {item.level && (
                      <Badge variant="outline" size="sm">
                        {item.level === 'expert'
                          ? 'Expert'
                          : item.level === 'proficient'
                            ? 'Proficient'
                            : 'Learning'}
                      </Badge>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </StaggerChildren>
    </Section>

    <Section id="about" container="narrow" background="default" spacing="lg">
      <Reveal direction="up" speed="normal" class="flex flex-col items-center gap-6 text-center">
        <Badge variant="default" size="sm">About</Badge>
        <Heading as="h2" size="4xl">
          Building software that <span class="text-gradient">puts food on the table</span>
        </Heading>
        <StaggerChildren
          as="div"
          stagger={120}
          initialDelay={100}
          class="max-w-2xl space-y-4 text-left text-lg text-text-soft"
        >
          <p>
            I'm Leo, a full-stack engineer from Heredia, Costa Rica. I run
            <strong class="text-text">FLProductions</strong>, a recording
            studio that's been live since 2013 and brings in 80% of its
            clients through the website.
          </p>
          <p>
            On the side I ship multi-tenant SaaS products:
            <strong class="text-text">Zamr</strong> for worship bands
            (load-tested to 500 WebSocket users) and
            <strong class="text-text">MejorMenu</strong> for local restaurants
            (3 clients live and growing).
          </p>
          <p>
            My favourite problems: real-time systems, multi-tenant
            architectures, and developer experience. I write the kind of docs
            I'd want to read — 4,000+ lines across the 3 projects.
          </p>
        </StaggerChildren>
      </Reveal>
    </Section>

    <Reveal direction="up" speed="normal">
      <ContactSection />
    </Reveal>
  </main>

  <Reveal direction="up" speed="fast" distance={8}>
    <footer class="border-t border-border py-8">
      <div
        class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-4 px-6 text-xs text-text-muted md:flex-row md:px-10"
      >
        <p>
          © {new Date().getFullYear()} Leonardo Serrano. Built with Astro 5 +
          Tailwind 4 + Framer Motion.
        </p>
        <p>Heredia, Costa Rica</p>
      </div>
    </footer>
  </Reveal>
</BaseLayout>
