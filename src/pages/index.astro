---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Leonardo Serrano — Full-Stack Engineer"
  description="Building production systems that scale. 3 active projects, ~159K lines of code, real users in production."
>
  <main class="container-narrow flex min-h-screen flex-col items-center justify-center gap-12 py-24">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-soft px-3 py-1 text-xs font-medium text-text-soft"
    >
      <span class="h-2 w-2 animate-pulse rounded-full bg-secundario"></span>
      Portfolio v2 — coming soon
    </span>

    <h1
      class="text-balance text-center text-5xl font-bold tracking-tight md:text-7xl"
    >
      Leonardo <span class="text-gradient">Serrano</span>
    </h1>

    <p
      class="max-w-2xl text-balance text-center text-lg text-text-soft md:text-xl"
    >
      Full-stack engineer from Costa Rica. Building production systems that
      scale — recording studios, multi-tenant SaaS, real-time platforms.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-md bg-primario px-5 py-3 text-sm font-semibold text-bg transition hover:bg-primario/90"
      >
        See the work
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="mailto:hola@leonardoserrano.site"
        class="inline-flex items-center gap-2 rounded-md border border-border bg-bg-soft px-5 py-3 text-sm font-semibold transition hover:border-secundario hover:text-secundario"
      >
        Get in touch
      </a>
    </div>

    <p class="mt-8 text-xs text-text-muted">
      Stack: Astro 5 · React 19 · Tailwind 4 · Framer Motion
    </p>
  </main>
</BaseLayout>
