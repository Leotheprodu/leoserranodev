---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import Section from '@components/ui/Section.astro';
import Heading from '@components/ui/Heading.astro';
import Badge from '@components/ui/Badge.astro';
import ThemeToggle from '@components/ui/ThemeToggle.astro';
---

<BaseLayout
  title="Leonardo Serrano — Full-Stack Engineer"
  description="Building production systems that scale. 3 active projects, ~159K lines of code, real users in production."
>
  <header
    class="sticky top-0 z-50 w-full border-b border-border/60 bg-bg/80 backdrop-blur-md"
  >
    <div
      class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-6 md:px-10"
    >
      <a
        href="/"
        class="flex items-center gap-2 text-sm font-bold tracking-tight"
      >
        <span
          class="grid h-7 w-7 place-items-center rounded-md bg-primario text-bg"
        >
          L
        </span>
        <span>Leonardo Serrano</span>
      </a>
      <nav class="flex items-center gap-2">
        <a
          href="#projects"
          class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
        >
          Projects
        </a>
        <a
          href="#about"
          class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
        >
          About
        </a>
        <a
          href="#contact"
          class="hidden text-sm text-text-soft transition hover:text-text md:inline-flex"
        >
          Contact
        </a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <Section
    container="wide"
    background="default"
    spacing="xl"
    class="relative overflow-hidden"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_20%,var(--color-secundario)/8,transparent_50%),radial-gradient(circle_at_70%_80%,var(--color-acento)/8,transparent_50%)]"
    >
    </div>

    <div class="flex flex-col items-center gap-8 text-center">
      <Badge variant="secundario" size="md">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-secundario"
        ></span>
        Portfolio v2 — building in public
      </Badge>

      <Heading
        as="h1"
        size="6xl"
        weight="black"
        gradient
        class="max-w-5xl"
      >
        Full-stack engineer building production systems that scale
      </Heading>

      <p
        class="max-w-2xl text-balance text-lg text-text-soft md:text-xl"
      >
        Costa Rica · 3 active products in production · ~159K lines of code ·
        real users every day
      </p>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <Button href="#projects" variant="primary" size="lg">
          See the work
          <span slot="icon-right" aria-hidden="true">→</span>
        </Button>
        <Button
          href="mailto:hola@leonardoserrano.site"
          variant="outline"
          size="lg"
        >
          Get in touch
        </Button>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-2 text-xs text-text-muted">
        <span>Stack:</span>
        <Badge variant="outline" size="sm">Astro 5</Badge>
        <Badge variant="outline" size="sm">React 19</Badge>
        <Badge variant="outline" size="sm">Tailwind 4</Badge>
        <Badge variant="outline" size="sm">Framer Motion</Badge>
        <Badge variant="outline" size="sm">NestJS</Badge>
        <Badge variant="outline" size="sm">Prisma</Badge>
        <Badge variant="outline" size="sm">Socket.IO</Badge>
      </div>
    </div>
  </Section>

  <Section id="projects" container="wide" background="soft" spacing="lg">
    <div class="mb-12 flex flex-col items-center gap-3 text-center">
      <Badge variant="default" size="sm">Featured</Badge>
      <Heading as="h2" size="4xl" gradient>What I'm shipping right now</Heading>
      <p class="max-w-2xl text-text-soft">
        Three production systems, each one a different domain, all built from
        scratch.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <Card variant="bento" padding="lg" hover="glow" class="lg:col-span-2">
        <div class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <Badge variant="secundario" size="sm">Lead project</Badge>
            <Badge variant="live" size="sm">13+ years live</Badge>
          </div>
          <Heading as="h3" size="2xl">FLProductions</Heading>
          <p class="text-text-soft">
            Recording studio website + artist portal + beat e-commerce. NestJS
            + Prisma + Next.js · 28 models · 202 endpoints · real-time sync.
          </p>
          <div class="mt-2 flex gap-2">
            <Button href="https://www.flproductionscr.com" target="_blank" variant="primary" size="sm">
              Live site
              <span slot="icon-right" aria-hidden="true">↗</span>
            </Button>
            <Button href="#" variant="ghost" size="sm">Case study</Button>
          </div>
        </div>
      </Card>

      <Card variant="bento" padding="lg" hover="glow">
        <div class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <Badge variant="acento" size="sm">SaaS</Badge>
            <Badge variant="live" size="sm">500+ users tested</Badge>
          </div>
          <Heading as="h3" size="xl">Zamr</Heading>
          <p class="text-text-soft">
            Worship band management. Multi-tenant, real-time lyrics, WebSocket
            gateway load-tested to 500 concurrent.
          </p>
          <div class="mt-2 flex gap-2">
            <Button href="https://www.zamr.app" target="_blank" variant="primary" size="sm">
              Live site
              <span slot="icon-right" aria-hidden="true">↗</span>
            </Button>
            <Button href="#" variant="ghost" size="sm">Case study</Button>
          </div>
        </div>
      </Card>

      <Card variant="bento" padding="lg" hover="glow">
        <div class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <Badge variant="highlight" size="sm">SaaS</Badge>
            <Badge variant="live" size="sm">3 clients</Badge>
          </div>
          <Heading as="h3" size="xl">MejorMenu</Heading>
          <p class="text-text-soft">
            Multi-tenant menus for restaurants in Costa Rica. AI image
            generation, WhatsApp deep-links, real-time orders.
          </p>
          <div class="mt-2 flex gap-2">
            <Button href="https://www.mejormenu.com" target="_blank" variant="primary" size="sm">
              Live site
              <span slot="icon-right" aria-hidden="true">↗</span>
            </Button>
            <Button href="#" variant="ghost" size="sm">Case study</Button>
          </div>
        </div>
      </Card>

      <Card variant="bento" padding="lg" hover="glow" class="md:col-span-2">
        <div class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <Badge variant="default" size="sm">E-commerce</Badge>
            <Badge variant="outline" size="sm">Part of FLProductions</Badge>
          </div>
          <Heading as="h3" size="2xl">Ackee Beats</Heading>
          <p class="text-text-soft">
            Beat marketplace with PayPal licensing, YouTube preview integration,
            and PDF license generation per purchase.
          </p>
          <div class="mt-2 flex gap-2">
            <Button href="https://www.ackeebeats.com" target="_blank" variant="primary" size="sm">
              Live site
              <span slot="icon-right" aria-hidden="true">↗</span>
            </Button>
          </div>
        </div>
      </Card>
    </div>
  </Section>

  <Section id="about" container="narrow" background="default" spacing="lg">
    <div class="flex flex-col items-center gap-6 text-center">
      <Badge variant="default" size="sm">About</Badge>
      <Heading as="h2" size="4xl">
        Building software that <span class="text-gradient">puts food on the table</span>
      </Heading>
      <p class="max-w-2xl text-lg text-text-soft">
        I'm Leo, a full-stack engineer from Costa Rica. I run a recording
        studio (FLProductions) and build SaaS products on the side. My
        favourite problems are real-time systems, multi-tenant architectures,
        and developer experience.
      </p>
    </div>
  </Section>

  <Section
    id="contact"
    container="narrow"
    background="primario"
    spacing="lg"
    class="text-center"
  >
    <div class="flex flex-col items-center gap-6">
      <Badge variant="highlight" size="sm">Get in touch</Badge>
      <Heading
        as="h2"
        size="5xl"
        class="text-bg"
      >
        Let's build something <span class="text-gradient">real</span>
      </Heading>
      <p class="max-w-xl text-base text-bg/80">
        Open to interesting projects, contract work, and full-time roles where
        the team ships production software with care.
      </p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <Button
          href="mailto:hola@leonardoserrano.site"
          variant="primary"
          size="lg"
          class="!bg-bg !text-primario hover:!bg-bg/90"
        >
          hola@leonardoserrano.site
        </Button>
        <Button
          href="https://github.com/Leotheprodu"
          target="_blank"
          variant="outline"
          size="lg"
          class="!border-bg/20 !text-bg hover:!border-highlight hover:!text-highlight"
        >
          GitHub
        </Button>
        <Button
          href="https://www.linkedin.com/in/leonardoserranodev"
          target="_blank"
          variant="outline"
          size="lg"
          class="!border-bg/20 !text-bg hover:!border-highlight hover:!text-highlight"
        >
          LinkedIn
        </Button>
      </div>
    </div>
  </Section>

  <footer class="border-t border-border py-8">
    <div
      class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-4 px-6 text-xs text-text-muted md:flex-row md:px-10"
    >
      <p>© {new Date().getFullYear()} Leonardo Serrano. Built with Astro 5 + Tailwind 4.</p>
      <p>Heredia, Costa Rica</p>
    </div>
  </footer>
</BaseLayout>
