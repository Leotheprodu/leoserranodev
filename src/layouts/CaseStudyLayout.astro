---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@components/layouts/Header.astro';
import Footer from '@components/layouts/Footer.astro';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';
import Heading from '@components/ui/Heading.astro';
import StatCard from '@components/bento/StatCard.astro';
import Reveal from '@components/motion/Reveal.astro';
import StaggerChildren from '@components/motion/StaggerChildren.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

interface Props {
  title: string;
  description: string;
  tagline: string;
  type: string;
  status: string;
  statusVariant?: 'live' | 'secundario' | 'default' | 'outline';
  liveUrl?: string;
  githubUrl?: string;
  stack: string[];
  metrics: Array<{ value: string; label: string }>;
  highlights: string[];
  publishedAt: Date;
}

const {
  title,
  description,
  tagline,
  type,
  status,
  statusVariant = 'live',
  liveUrl,
  githubUrl,
  stack,
  metrics,
  highlights,
  publishedAt,
} = Astro.props as Props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const typeLabel: Record<string, string> = {
  saas: 'SaaS',
  ecommerce: 'E-commerce',
  studio: 'Studio',
  platform: 'Platform',
};

const formattedDate = publishedAt.toLocaleDateString(
  lang === 'es' ? 'es-ES' : 'en-US',
  { year: 'numeric', month: 'long' }
);
---

<BaseLayout title={title} description={description}>
  <Header activeSection="projects" />

  <main>
    <article class="relative">
      <section
        class="relative overflow-hidden border-b border-border/60 py-16 md:py-24"
      >
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_20%,var(--color-secundario)/10,transparent_45%),radial-gradient(circle_at_80%_80%,var(--color-acento)/8,transparent_45%)]"
        >
        </div>

        <div class="mx-auto max-w-7xl px-6 md:px-10">
          <Reveal direction="up" speed="fast" class="mb-8">
            <a
              href={getLocalizedPath('/projects', lang)}
              class="inline-flex items-center gap-2 text-sm text-text-soft transition hover:text-text"
            >
              <span aria-hidden="true">←</span>
              {t('caseStudy.backToAll')}
            </a>
          </Reveal>

          <div class="grid gap-12 lg:grid-cols-[1fr_22rem]">
            <Reveal direction="up" speed="normal" class="flex flex-col gap-6">
              <div class="flex flex-wrap items-center gap-2">
                <Badge variant="default" size="md">{typeLabel[type]}</Badge>
                <Badge variant={statusVariant} size="md">
                  {status === 'live' ? '● Live' : status}
                </Badge>
                <span class="text-xs text-text-muted">
                  {t('caseStudy.publishedOn')} {formattedDate}
                </span>
              </div>

              <Heading as="h1" size="6xl" weight="black" gradient class="text-balance">
                {title}
              </Heading>

              <p class="max-w-2xl text-balance text-lg text-text-soft md:text-xl">
                {tagline}
              </p>

              <div class="mt-2 flex flex-wrap gap-3">
                {liveUrl && (
                  <Button href={liveUrl} target="_blank" variant="primary" size="lg">
                    {t('caseStudy.visitLive')}
                    <span slot="icon-right" aria-hidden="true">↗</span>
                  </Button>
                )}
                {githubUrl && (
                  <Button
                    href={githubUrl}
                    target="_blank"
                    variant="outline"
                    size="lg"
                  >
                    GitHub
                    <span slot="icon-right" aria-hidden="true">↗</span>
                  </Button>
                )}
              </div>

              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="text-xs text-text-muted">{t('caseStudy.stackLabel')}:</span>
                {
                  stack.map((tech) => (
                    <Badge variant="outline" size="sm">{tech}</Badge>
                  ))
                }
              </div>
            </Reveal>

            <aside class="lg:sticky lg:top-24 lg:self-start">
              <Reveal direction="right" speed="normal">
                <div
                  class="rounded-lg border border-border bg-surface p-6 shadow-sm"
                >
                  <h2 class="mb-4 text-sm font-bold uppercase tracking-wider text-text-soft">
                    {t('caseStudy.tldr')}
                  </h2>

                  <div class="mb-6 grid grid-cols-2 gap-3">
                    {
                      metrics.map((m) => (
                        <div class="flex flex-col gap-0.5">
                          <span class="text-2xl font-black tracking-tight text-text">
                            {m.value}
                          </span>
                          <span class="text-xs text-text-muted">{m.label}</span>
                        </div>
                      ))
                    }
                  </div>

                  <h3 class="mb-3 text-xs font-bold uppercase tracking-wider text-text-soft">
                    {t('caseStudy.highlights')}
                  </h3>
                  <ul class="flex flex-col gap-2 text-sm text-text-soft">
                    {
                      highlights.slice(0, 4).map((h) => (
                        <li class="flex items-start gap-2">
                          <span class="mt-1.5 inline-block h-1 w-1 flex-shrink-0 rounded-full bg-secundario" />
                          <span>{h}</span>
                        </li>
                      ))
                    }
                  </ul>
                </div>
              </Reveal>
            </aside>
          </div>
        </div>
      </section>

      <div class="mx-auto max-w-3xl px-6 py-16 md:px-0 md:py-24">
        <div class="prose prose-lg max-w-none">
          <slot />
        </div>
      </div>
    </article>

    <section class="border-t border-border bg-bg-soft py-16">
      <div class="mx-auto max-w-7xl px-6 md:px-10">
        <Reveal direction="up" class="mb-8 text-center">
          <Heading as="h2" size="3xl">
            {t('caseStudy.otherCaseStudies')}
          </Heading>
        </Reveal>
        <StaggerChildren
          as="div"
          stagger={100}
          class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
        >
          <slot name="related" />
        </StaggerChildren>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .prose {
    color: var(--color-text);
  }
  .prose h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .prose p {
    margin: 1rem 0;
    line-height: 1.7;
    color: var(--color-text-soft);
  }
  .prose strong {
    color: var(--color-text);
    font-weight: 700;
  }
  .prose a {
    color: var(--color-secundario);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    color: var(--color-acento);
  }
  .prose ul,
  .prose ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: var(--color-text-soft);
  }
  .prose li {
    margin: 0.5rem 0;
    line-height: 1.6;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-secundario);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-soft);
  }
  .prose code {
    background: var(--color-bg-soft);
    color: var(--color-secundario);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: var(--font-mono);
  }
  .prose pre {
    background: var(--color-primario);
    color: #fafafa;
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85em;
    line-height: 1.55;
  }
  .prose pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
  .prose hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }
</style>
